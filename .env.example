# .env.local — copy this to .env.local and fill in your values

# Supabase / Neon / Railway Postgres connection string
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://..."

# Upstash Redis URL (from Upstash dashboard → REST URL — use ioredis format)
# Format: rediss://default:password@host:port
REDIS_URL="rediss://..."

# Vercel Cron protection secret — set this in Vercel dashboard env vars too
CRON_SECRET="your-random-secret-here"
